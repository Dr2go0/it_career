@model List<it_career.models.BookedFilmsViewModel>

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2 class="mb-0">My Bookings</h2>
        <p class="text-muted mb-0">Logged in as <strong>@ViewBag.UserEmail</strong></p>
    </div>
</div>

@if (!Model.Any())
{
    <div class="text-center text-muted py-5">
        <p class="fs-5">You have no bookings yet.</p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary">Browse Cinemas</a>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4" id="bookedFilms">
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">@item.FilmName</h5>
                        <p class="text-muted mb-0">🗓 @item.ProjectionDate.ToString("dd MMM yyyy, HH:mm")</p>
                    </div>
                    <div class="card-footer bg-transparent">
                        <span class="badge bg-success">Booked</span>
                    </div>
                </div>
            </div>
        }
    </div>
}