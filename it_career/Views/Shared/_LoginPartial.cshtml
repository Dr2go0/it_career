@using Microsoft.AspNetCore.Identity
@using it_career.data.models
@inject SignInManager<AppUser> SignInManager
@inject UserManager<AppUser> UserManager

<ul class="navbar-nav">
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="nav-item d-flex align-items-center me-2">
            <span class="text-secondary small">👤 @UserManager.GetUserName(User)</span>
        </li>
        <li class="nav-item">
            <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post">
                <button type="submit" class="btn btn-sm btn-outline-light">Log out</button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="btn btn-sm btn-outline-light me-2" asp-area="Identity" asp-page="/Account/Login">Log in</a>
        </li>
        <li class="nav-item">
            <a class="btn btn-sm btn-light" asp-area="Identity" asp-page="/Account/Register">Register</a>
        </li>
    }
</ul>